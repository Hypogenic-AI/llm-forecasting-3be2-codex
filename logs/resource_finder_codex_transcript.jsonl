{"type":"item.started","item":{"id":"item_66","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\nbase = Path('datasets')\nplans = [\n    ('forecast_questions_forecast', lambda: load_dataset('MoyYuan/FOReCAst')),\n    ('forecast_questions_platforms', lambda: load_dataset('YuehHanChen/forecasting')),\n    ('timeseries_etth1', lambda: load_dataset('thuml/Time-Series-Library', 'ETTh1')),\n    ('timeseries_m4_hourly', lambda: load_dataset('thuml/Time-Series-Library', 'm4-hourly')),\n]\nfor out_name, loader in plans:\n    ds = loader()\n    out = base / out_name\n    ds.save_to_disk(str(out))\n    sample_dir = out / 'samples'\n    sample_dir.mkdir(parents=True, exist_ok=True)\n    sample = {}\n    for split, split_ds in ds.items():\n        n = min(10, len(split_ds))\n        sample[split] = split_ds.select(range(n)).to_list()\n    (sample_dir / 'samples.json').write_text(json.dumps(sample, indent=2, default=str))\n    print(f'SAVED {out_name}')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
